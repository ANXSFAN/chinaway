# Supabase (hosted PostgreSQL)
DATABASE_URI=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Payload
PAYLOAD_SECRET=your-payload-secret-min-32-chars-long

# Supabase Storage (S3-compatible)
S3_BUCKET=media
S3_ENDPOINT=https://YOUR_PROJECT_REF.supabase.co/storage/v1/s3
S3_REGION=eu-west-1
S3_ACCESS_KEY_ID=your-s3-access-key
S3_SECRET_ACCESS_KEY=your-s3-secret-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Site
NEXT_PUBLIC_BASE_URL=http://localhost:3000
